{
    "name": "docusign/monitor-client",
    "description": "The Docusign package makes integrating Docusign into your apps and websites a super fast and painless process. The library is open sourced on GitHub, look for the docusign-monitor-php-client repository.",
    "keywords": [
        "Docusign",
        "Monitor",
        "php",
        "sdk",
        "api"
    ],
    "homepage": "https://developers.docusign.com",
    "license": "MIT",
    "authors": [
        {
            "name": "DocuSign",
            "homepage": "https://developers.docusign.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "adhocore/jwt": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "~4.8",
        "satooshi/php-coveralls": "~1.0",
        "squizlabs/php_codesniffer": "~2.6",
        "friendsofphp/php-cs-fixer": "*"
    },
    "autoload": {
        "psr-4": { "DocuSign\\Monitor\\" : "src/" }
    },
    "autoload-dev": {
        "psr-4": { "DocuSign\\Monitor\\" : "test/" }
    }
}